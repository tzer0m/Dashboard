@page
@model IndexModel
@using Dashboard.Models
@{
    ViewData["Title"] = "Dashboard";
    Dictionary<string, List<ServiceEntry>> singleService = Model.ServicesByDevice.Where(d => d.Value.Count == 1).OrderBy(d => d.Key).ToDictionary(d => d.Key, d => d.Value.OrderBy(s => s.Name).ToList());
    Dictionary<string, List<ServiceEntry>> multiService = Model.ServicesByDevice.Where(d => d.Value.Count > 1).OrderBy(d => d.Key).ToDictionary(d => d.Key, d => d.Value.OrderBy(s => s.Name).ToList());
}

<div class="mb-5 d-none d-md-block">
    @if (Model.DnsUpdates.Any())
    {
        <div class="row g-3">
            @foreach (DnsUpdate update in Model.DnsUpdates)
            {
                bool isCurrent = update == Model.DnsUpdates.First();
                <div class="col-12 col-md">
                    <div class="px-3 py-2 @(isCurrent ? "" : "opacity-50")">
                        <div class="fw-medium">@update.IpAddress</div>
                        <div class="text-secondary small">@update.RecordedAt.ToString("yyyy-MM-dd HH:mm") UTC</div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<div class="row g-3 mb-5">
    @foreach (KeyValuePair<string, List<ServiceEntry>> device in singleService)
    {
        <div class="col-12 col-md-4">
            <div class="mb-2">
                <span class="fw-medium">@device.Key</span>
                <span class="text-secondary small ms-2">@device.Value.First().LocalIp</span>
            </div>
            @await Html.PartialAsync("_ServiceCard", new ServiceCard
            {
                Service = device.Value.First(),
                Status = Model.Statuses.GetValueOrDefault(device.Value.First().Name),
                FaviconUrl = device.Value.First().FaviconUrl
            })
        </div>
    }
</div>

@foreach (KeyValuePair<string, List<ServiceEntry>> device in multiService)
{
    <div class="mb-4 mt-5">
        <div class="mb-2">
            <span class="fw-medium">@device.Key</span>
            <span class="text-secondary small ms-2">@device.Value.First().LocalIp</span>
        </div>
        <div class="row g-3">
            @foreach (ServiceEntry service in device.Value)
            {
                <div class="col-12 col-md-4">
                    @await Html.PartialAsync("_ServiceCard", new ServiceCard
                    {
                        Service = service,
                        Status = Model.Statuses.GetValueOrDefault(service.Name),
                        FaviconUrl = service.FaviconUrl
                    })
                </div>
            }
        </div>
    </div>
}

@section Scripts {
    <script>
        setTimeout(() => location.reload(), 10000);
    </script>
}