@page
@model Dashboard.Pages.HomeAssistantModel
@using Dashboard.Models
@{
    Layout = "_HomeAssistantLayout";
}

<div class="p-2" style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem 0.75rem;">
    @foreach (ServiceEntry service in Model.Services)
    {
        ServiceStatus? status = Model.Statuses.GetValueOrDefault(service.Name);
        string badgeClass = status == null ? "bg-secondary" : status.IsOnline ? "bg-success" : "bg-danger";
        string badgeText = status == null ? "Pending" : status.IsOnline ? "Online" : "Offline";
        string faviconSrc = service.FaviconUrl ?? $"/Favicon?url={Uri.EscapeDataString(service.Url)}";
        bool isGlobal = service.Access == "Global";

        <a href="@service.Url" target="_blank" rel="noopener noreferrer" class="d-flex align-items-center gap-2 p-2 rounded text-decoration-none text-reset" style="border: 1px solid rgba(255,255,255,0.1); min-width: 0;">
            <img src="@faviconSrc" width="14" height="14" onerror="this.style.display='none'" style="flex-shrink: 0;" />
            <span class="flex-grow-1 text-truncate" style="min-width: 0;">@service.Name</span>
            @if (status != null)
            {
                <span class="text-secondary small" style="flex-shrink: 0;">@status.ResponseTimeMs ms</span>
            }
            <span class="text-secondary d-inline-flex" title="@service.Access" style="flex-shrink: 0;">
                @if (isGlobal)
                {
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="2" y1="12" x2="22" y2="12"></line>
                        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                    </svg>
                }
                else
                {
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9.5 12 3l9 6.5V20a1 1 0 0 1-1 1h-5v-7H9v7H4a1 1 0 0 1-1-1z"></path>
                    </svg>
                }
            </span>
            <span class="badge @badgeClass" style="flex-shrink: 0;">@badgeText</span>
        </a>
    }
</div>

@section Scripts {
    <script>
        setTimeout(() => location.reload(), 10000);
    </script>
}