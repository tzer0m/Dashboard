@model Dashboard.Models.ServiceCard
@{
    string badgeClass = Model.Status == null ? "bg-secondary" : Model.Status.IsOnline ? "bg-success" : "bg-danger";
    string badgeText = Model.Status == null ? "Pending" : Model.Status.IsOnline ? "Online" : "Offline";
    string displayUrl = Model.Service.Url.Replace("https://", "").Replace("http://", "");
    string faviconSrc = Model.FaviconUrl ?? $"/Favicon?url={Uri.EscapeDataString(Model.Service.Url)}";
    bool isGlobal = Model.Service.Access == "Global";
}

<a href="@Model.Service.Url" target="_blank" rel="noopener noreferrer" class="card text-decoration-none text-reset d-block" style="cursor: pointer;">
    <div class="card-body">
        <div class="d-flex align-items-center gap-2 mb-2">
            <img src="@faviconSrc" width="16" height="16" onerror="this.style.display='none'" />
            <h6 class="card-title mb-0">@Model.Service.Name</h6>
            <span class="d-inline-flex align-items-center gap-2 ms-auto">
                <span class="text-secondary d-inline-flex" title="@Model.Service.Access" style="flex-shrink: 0;">
                    @if (isGlobal)
                    {
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="2" y1="12" x2="22" y2="12"></line>
                            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                        </svg>
                    }
                    else
                    {
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 9.5 12 3l9 6.5V20a1 1 0 0 1-1 1h-5v-7H9v7H4a1 1 0 0 1-1-1z"></path>
                        </svg>
                    }
                </span>
                <span class="badge @badgeClass">@badgeText</span>
            </span>
        </div>
        <div class="d-flex justify-content-between align-items-center mb-1">
            <p class="text-secondary small mb-0">@Model.Service.Type</p>
            @if (!string.IsNullOrEmpty(Model.Service.RepoName))
            {
                <img src="https://img.shields.io/github/actions/workflow/status/@(Model.Service.RepoName)/deploy.yml?branch=master&style=flat-square&label=deploy&labelColor=212529&logo=github&logoColor=8b949e" alt="Deploy status">
            }
        </div>
        <p class="small fs-6 mb-0 text-secondary">@displayUrl</p>
        @if (Model.Status != null)
        {
            <div class="mt-2 text-secondary" style="font-size: 0.75rem;">
                <span>@Model.Status.ResponseTimeMs ms</span>
                <span class="ms-2">@Model.Status.LastChecked.ToString("HH:mm:ss") UTC</span>
            </div>
        }
    </div>
</a>